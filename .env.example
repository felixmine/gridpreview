# Kopiere diese Datei zu `.env.local` und trage die Werte aus deinem
# Supabase-Projekt ein (Dashboard > Project Settings > API).
#
# WICHTIG: Nur Variablen, die mit VITE_ beginnen, sind im Browser verfügbar.
# Verwende hier NIEMALS den `service_role` Key - nur den `anon` Public Key!

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
